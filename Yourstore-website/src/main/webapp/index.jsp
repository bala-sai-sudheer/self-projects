    </div>

    <div class="card">
        <img src="images/home.jpg">
        <h3>Home</h3>
    </div>

    <div class="card">
        <img src="images/books.jpg">
        <h3>Books</h3>
    </div>

    <div class="card">
        <img src="images/toys.jpg">
        <h3>Toys</h3>
