<!DOCTYPE html>
<html>
<head>
    <title>YourStore - Online Shopping</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>

<header>
    <h1>YourStore</h1>
    <input type="text" placeholder="Search products...">
</header>

<nav>
    <ul>
        <li>Electronics</li>
        <li>Fashion</li>
        <li>Home</li>
