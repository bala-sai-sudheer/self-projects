FROM nginx:alpine

# Copy web files
COPY src/WebClient/ /usr/share/nginx/html/

# Simple nginx config without proxy to gateway
RUN echo 'server { \
    listen 80; \
    server_name _; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80
